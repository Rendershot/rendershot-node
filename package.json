{
  "name": "rendershot",
  "version": "0.1.1",
  "description": "Node.js SDK for the Rendershot screenshot & PDF generation API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "screenshot",
    "pdf",
    "rendershot",
    "api",
    "sdk",
    "html-to-pdf",
    "html-to-image",
    "url-to-screenshot"
  ],
  "author": "Rendershot",
  "license": "MIT",
  "homepage": "https://rendershot.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rendershot/rendershot-node.git"
  },
  "bugs": {
    "url": "https://github.com/Rendershot/rendershot-node/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
